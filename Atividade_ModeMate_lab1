        "from scipy.optimize import linprog\n",
        "\n",
        "# Função objetivo (negativa para maximizar)\n",
        "c = [-40, -60]\n",
        "\n",
        "# Restrições\n",
        "A = [\n",
        "    [4, 2],\n",
        "    [2, 2],\n",
        "    [2, 6]\n",
        "]\n",
        "\n",
        "b = [140, 80, 180]\n",
        "\n",
        "# Limites\n",
        "bounds = [(0, None), (0, None)]\n",
        "\n",
        "# Resolver\n",
        "res = linprog(c, A_ub=A, b_ub=b, bounds=bounds, method='highs')\n",
        "\n",
        "if res.success:\n",
        "    x, y = res.x\n",
        "    print(\"Para maximizar o problema de PL\")\n",
        "    print(f\"{x:.2f} tem que ser X\")\n",
        "    print(f\"{y:.2f} tem que ser X2\")\n",
        "    print(f\"Custo total: R$ {-res.fun:.2f}\")\n",
        "else:\n",
        "    print(\"Não foi possível encontrar uma solução viável.\")"

        "# Importa bibliotecas necessárias\n",
        "import matplotlib.pyplot as plt      # biblioteca para criar gráficos\n",
        "import numpy as np                   # biblioteca para cálculos numéricos\n",
        "from scipy.optimize import linprog   # função para resolver programação linear\n",
        "\n",
        "# Cria vários valores de x entre 0 e 40 para desenhar as retas\n",
        "x_vals = np.linspace(0, 40, 400)\n",
        "\n",
        "# Converte as restrições para forma de função (y em função de x)\n",
        "# 4x + 2y = 140  -> y = (140 - 4x) / 2\n",
        "a = (140 - 4 * x_vals) / 2\n",
        "\n",
        "# 2x + 2y = 80 -> y = (80 - 2x) / 2\n",
        "b = (80 - 2 * x_vals) / 2\n",
        "\n",
        "# 2x + 6y = 180 -> y = (180 - 2x) / 6\n",
        "c = (180 - 2 * x_vals) / 6\n",
        "\n",
        "# Função objetivo (negativa porque o linprog resolve minimização)\n",
        "# Queremos maximizar 40x + 60y\n",
        "C = [-40, -60]\n",
        "\n",
        "# Matriz das restrições (coeficientes de x e y)\n",
        "A = [\n",
        "    [4, 2],\n",
        "    [2, 2],\n",
        "    [2, 6]\n",
        "]\n",
        "\n",
        "# Limites das restrições\n",
        "B = [140, 80, 180]\n",
        "\n",
        "# Define limites das variáveis (x >= 0 e y >= 0)\n",
        "bounds = [(0, None), (0, None)]\n",
        "\n",
        "# Resolve o problema de programação linear\n",
        "res = linprog(C, A_ub=A, b_ub=B, bounds=bounds, method='highs')\n",
        "\n",
        "# Cria a figura do gráfico\n",
        "plt.figure(figsize=(10,6))\n",
        "\n",
        "# Desenha as retas das restrições\n",
        "plt.plot(x_vals, a, label='4x + 2y = 140', color='blue')\n",
        "plt.plot(x_vals, b, label='2x + 2y = 80', color='green')\n",
        "plt.plot(x_vals, c, label='2x + 6y = 180', color='orange')\n",
        "\n",
        "# Cria valores de y para formar uma grade de pontos\n",
        "y_vals = np.linspace(0, 50, 400)\n",
        "\n",
        "# Cria uma malha (grid) de pontos x e y\n",
        "x_grid, y_grid = np.meshgrid(x_vals, y_vals)\n",
        "\n",
        "# Define a região viável (onde todas as restrições são satisfeitas)\n",
        "region = (\n",
        "    (4*x_grid + 2*y_grid <= 140) &\n",
        "    (2*x_grid + 2*y_grid <= 80) &\n",
        "    (2*x_grid + 6*y_grid <= 180)\n",
        ")\n",
        "\n",
        "# Preenche a região viável com uma cor cinza clara\n",
        "plt.contourf(\n",
        "    x_grid, y_grid, region,\n",
        "    levels=[0.5, 1],\n",
        "    colors=['#d3d3d3'],\n",
        "    alpha=0.5\n",
        ")\n",
        "\n",
        "# Marca o ponto da solução ótima encontrado pelo linprog\n",
        "plt.plot(res.x[0], res.x[1], 'ro', label='Solução ótima')\n",
        "\n",
        "# Mostra as coordenadas do ponto ótimo no gráfico\n",
        "plt.text(\n",
        "    res.x[0], res.x[1],\n",
        "    f\" ({res.x[0]:.2f}, {res.x[1]:.2f})\"\n",
        ")\n",
        "\n",
        "# Nome dos eixos\n",
        "plt.xlabel('X1')\n",
        "plt.ylabel('X2')\n",
        "\n",
        "# Título do gráfico\n",
        "plt.title('Região Viável e Solução Ótima')\n",
        "\n",
        "# Mostra legenda das retas\n",
        "plt.legend()\n",
        "\n",
        "# Ativa grade no gráfico\n",
        "plt.grid(True)\n",
        "\n",
        "# Define limites dos eixos\n",
        "plt.xlim(0, 40)\n",
        "plt.ylim(0, 70)\n",
        "\n",
        "# Salva o gráfico como imagem\n",
        "plt.savefig(\"grafico.png\")\n",
        "\n",
        "# Mostra o gráfico na tela\n",
        "plt.show()"
